{
  "name": "@mrkirby153/forms",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts src/client.ts --format cjs,esm --dts --minify --no-splitting",
    "watch": "tsup src/index.ts src/client.ts --format cjs,esm --dts --minify --no-splitting --watch"
  },
  "keywords": [],
  "author": "mrkirby153",
  "license": "MIT",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": "^19.0.0 || ^18.0.0",
    "react-dom": "^19.0.0 || ^18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4"
  }
